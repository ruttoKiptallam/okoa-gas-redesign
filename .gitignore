# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Node / package manager ---
/node_modules
**/node_modules
.pnp
.pnp.js

# --- Build / distribution outputs ---
/build
/frontend/build
/okoa-gas-backend/build
/dist
*.tgz
*.tar.gz

# --- Test coverage ---
/coverage
.nyc_output

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# --- Runtime data ---
pids
*.pid
*.pid.lock

# --- Environment / secrets ---
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
okoa-gas-backend/.env*

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDE files ---
.vscode
.idea
*.sublime-project
*.sublime-workspace

# --- Caches ---
.cache/
.tmp/
temp/
*.cache
.eslintcache
.parcel-cache

# --- Project-specific personal / scratch files (never commit) ---
blackbox_mcp_settings.json
check.js
TODO.md
DEPLOY_SEPARATE_FRONTEND_BACKEND.md
package-lock.json  # root-level only — no package.json at root
