{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "okoa-gas-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/okoa-gas-backend/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/build/$1" }
  ]
}